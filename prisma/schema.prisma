// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  name      String?
  bookmarks Bookmark[]
}

model Bookmark {
  id     Int    @id @default(autoincrement())
  link   String
  user   User?  @relation(fields: [userId], references: [id])
  userId Int?
}
