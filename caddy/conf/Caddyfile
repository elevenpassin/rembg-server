# http://localhost and https://localhost (Caddy uses its local CA for HTTPS; accept browser prompt once)
http://localhost, https://localhost {
	handle /upload {
		reverse_proxy app:3000
	}
	handle /health {
		reverse_proxy app:3000
	}
	handle /health/rembg {
		reverse_proxy app:3000
	}
	handle {
		root * /srv
		file_server
	}
}
